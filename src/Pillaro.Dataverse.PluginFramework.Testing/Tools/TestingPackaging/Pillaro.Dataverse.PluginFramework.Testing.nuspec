<?xml version="1.0"?>
<package>
	<metadata>
		<id>Pillaro.Dataverse.PluginFramework.Testing</id>
		<version>$version$</version>
		<authors>Pillaro Labs s.r.o.</authors>
		<owners>Pillaro Labs s.r.o.</owners>
		<copyright>Copyright © 2026 Pillaro Labs s.r.o.</copyright>

		<requireLicenseAcceptance>false</requireLicenseAcceptance>
		<license type="file">LICENSE</license>

        <projectUrl>https://github.com/Pillaro-Standard/Dataverse-Plugin-Framework</projectUrl>
		<repository type="git" url="https://github.com/Pillaro-Standard/Dataverse-Plugin-Framework" />

		<readme>docs\README.md</readme>
		<icon>icon.png</icon>

		<description>
			Testing support package for integration and end-to-end testing of solutions built with Pillaro Dataverse Plugin Framework.
		</description>

		<releaseNotes>https://github.com/Pillaro-Standard/Dataverse-Plugin-Framework/blob/main/CHANGELOG.md</releaseNotes>

		<tags>dataverse dynamics365 plugin testing integration-testing</tags>

		<dependencies>
			<group targetFramework="net8.0">
				<dependency id="Pillaro.Dataverse.PluginFramework" version="$version$" exclude="Build,Analyzers" />
				<dependency id="Autofac" version="9.1.0" />
				<dependency id="Microsoft.Extensions.Caching.Memory" version="8.0.1" />
				<dependency id="Microsoft.Extensions.Configuration.Json" version="8.0.0" />
				<dependency id="Microsoft.Extensions.Configuration.EnvironmentVariables" version="8.0.0" />
				<dependency id="Microsoft.PowerPlatform.Dataverse.Client" version="1.2.10" />
				<dependency id="xunit.v3.extensibility.core" version="3.2.2" />
			</group>
		</dependencies>
	</metadata>

	<files>
		<file src="..\..\icon.png" target="icon.png" />
		<file src="..\..\LICENSE" target="LICENSE" />
		<file src="README.md" target="docs\" />
		<file src="bin\$configuration$\net8.0\Pillaro.Dataverse.PluginFramework.Testing.dll" target="lib\net8.0" />
		<file src="bin\$configuration$\net8.0\Pillaro.Dataverse.PluginFramework.Testing.pdb" target="lib\net8.0" />
		<file src="bin\$configuration$\net8.0\Pillaro.Dataverse.PluginFramework.Testing.xml" target="lib\net8.0" />
	</files>
</package>
