<?xml version="1.0"?>
<package>
	<metadata>
		<id>Pillaro.Dataverse.PluginFramework</id>
		<version>$version$</version>
		<authors>Pillaro Labs s.r.o.</authors>
		<owners>Pillaro Labs s.r.o.</owners>
		<copyright>Copyright © 2026 Pillaro Labs s.r.o.</copyright>

		<requireLicenseAcceptance>false</requireLicenseAcceptance>
		<license type="file">LICENSE</license>

		<projectUrl>https://github.com/Pillaro-Standard/Dataverse-Plugin-Framework</projectUrl>
		<repository type="git" url="https://github.com/Pillaro-Standard/Dataverse-Plugin-Framework" />

		<description>
			Lightweight framework for building Microsoft Dataverse plugins with focus on testability,
			structure, and maintainability. Designed for real-world enterprise usage with support for
			logging, and consistent plugin architecture.
		</description>

		<releaseNotes>
			Initial public release of Pillaro Dataverse Plugin Framework including base framework assembly,
			XML documentation, and build tooling for Dataverse plugin packaging.
		</releaseNotes>

		<tags>dataverse dynamics crm plugin framework xrm</tags>

		<dependencies>
			<group targetFramework=".NETFramework4.6.2">
				<dependency id="Microsoft.CrmSdk.CoreAssemblies" version="9.0.2.60" />
				<dependency id="Newtonsoft.Json" version="13.0.1" />
			</group>
		</dependencies>
	</metadata>

	<files>
		<file src="..\..\..\..\LICENSE" target="LICENSE" />
		<file src="..\..\bin\$configuration$\Pillaro.Dataverse.PluginFramework.dll" target="lib\net462" />
		<file src="..\..\bin\$configuration$\Pillaro.Dataverse.PluginFramework.xml" target="lib\net462" />
		<file src="..\..\bin\$configuration$\Tools\ILMerge\ILMerge.exe" target="Content\Tools" />
		<file src="..\..\bin\$configuration$\Tools\ILMerge\System.Compiler.dll" target="Content\Tools" />
		<file src="..\..\bin\$configuration$\Tools\ILMerge\PostBuildAction.txt" target="Content\CrmTools" />
	</files>
</package>