<?xml version="1.0"?>
<package>
	<metadata>
		<id>Pillaro.Dataverse.PluginFramework</id>
		<version>$version$</version>
		<authors>Pillaro Labs s.r.o.</authors>
		<owners>Pillaro Labs s.r.o.</owners>
		<copyright>Copyright © 2026 Pillaro Labs s.r.o.</copyright>

		<requireLicenseAcceptance>false</requireLicenseAcceptance>
		<license type="file">LICENSE</license>

		<projectUrl>https://github.com/Pillaro-Standard/Dataverse-Plugin-Framework</projectUrl>
		<repository type="git" url="https://github.com/Pillaro-Standard/Dataverse-Plugin-Framework" />

		<readme>docs\README.md</readme>
		<icon>icon.png</icon>

		<description>
			Lightweight framework for building Microsoft Dataverse plugins with focus on testability,
			structure, and maintainability. Designed for real-world enterprise usage with support for
			logging and consistent plugin architecture.
		</description>

		<releaseNotes>$releaseNotes$</releaseNotes>

		<tags>dataverse dynamics crm plugin framework xrm</tags>

		<dependencies>
			<group targetFramework=".NETFramework4.6.2">
				<dependency id="Microsoft.CrmSdk.CoreAssemblies" version="9.0.2.60" />
				<dependency id="Newtonsoft.Json" version="13.0.4" />
			</group>

			<group targetFramework="net8.0">
				<dependency id="Microsoft.PowerPlatform.Dataverse.Client" version="1.2.10" />
				<dependency id="Newtonsoft.Json" version="13.0.4" />
				<dependency id="System.Runtime.Caching" version="8.0.0" />
			</group>
		</dependencies>
	</metadata>

	<files>
		<file src="..\..\LICENSE" target="LICENSE" />
		<file src="..\..\icon.png" target="icon.png" />
		<file src="README.md" target="docs\" />

		<file src="bin\$configuration$\net462\Pillaro.Dataverse.PluginFramework.dll" target="lib\net462" />
		<file src="bin\$configuration$\net462\Pillaro.Dataverse.PluginFramework.xml" target="lib\net462" />

		<file src="bin\$configuration$\net8.0\Pillaro.Dataverse.PluginFramework.dll" target="lib\net8.0" />
		<file src="bin\$configuration$\net8.0\Pillaro.Dataverse.PluginFramework.xml" target="lib\net8.0" />

		<file src="bin\$configuration$\net462\Tools\ILMerge\ILMerge.exe" target="contentFiles\any\any\Tools\ILMerge" />
		<file src="bin\$configuration$\net462\Tools\ILMerge\System.Compiler.dll" target="contentFiles\any\any\Tools\ILMerge" />
		<file src="bin\$configuration$\net462\Tools\ILMerge\PostBuildAction-logic_plugin-projects.txt" target="contentFiles\any\any\Tools\CrmTools" />
		<file src="bin\$configuration$\net462\Tools\ILMerge\PostBuildAction-single-project.txt" target="contentFiles\any\any\Tools\CrmTools" />
	</files>
</package>