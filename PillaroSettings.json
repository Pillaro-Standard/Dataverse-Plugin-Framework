{
  "solution": "ContosoCore",
  "plugins": {
    "assembly": "bin/Release/net462/Contoso.Plugins.dll",
    "manifest": "artifacts/plugin-manifest.json",
    "pluginId": "00000000-0000-0000-0000-000000000000",
    "pluginType": "Assembly"
  },
  "earlyBound": {
    "out": "src/Dataverse/Model",
    "namespace": "Contoso.Dataverse.Model",
    "serviceContextName": "DataverseContext",
    "language": "en-US",
    "includeSolutionEntities": true,
    "entities": [
      "account",
      "contact"
    ],
    "generateSdkMessages": true,
    "messages": [
    ],
    "emitFieldsClasses": true,
    "emitVirtualAttributes": true,
    "suppressINotifyPattern": true,
    "suppressGeneratedCodeAttribute": false,
    "entityTypesFolder": "Entities",
    "messagesTypesFolder": "Messages",
    "optionSetsTypesFolder": "OptionSets"
  }
}
